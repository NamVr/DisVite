{
	"name": "disvite",
	"version": "1.1.0",
	"description": "An advanced discord tracking module with native mongoose support.",
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"scripts": {
		"build": "tsc",
		"prepublishOnly": "npm run build",
		"test": "echo \"Error: no test specified\" && exit 1",
		"docs": "typedoc --entryPoints src/index.ts --out docs"
	},
	"files": [
		"dist"
	],
	"engines": {
		"node": ">=20"
	},
	"sideEffects": false,
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		}
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/NamVr/DisVite.git"
	},
	"homepage": "https://disvite.namanvrati.me",
	"bugs": {
		"url": "https://github.com/NamVr/DisVite/issues"
	},
	"keywords": [
		"discord",
		"invite",
		"tracker",
		"mongoose",
		"bot",
		"disvite",
		"discord-invite",
		"discord-bot",
		"discord-invite-manager",
		"mongodb",
		"discord.js",
		"discordjs",
		"invite-tracker",
		"analytics"
	],
	"author": "Naman Vrati",
	"license": "GPL-3.0",
	"dependencies": {
		"discord.js": "^14.x.x",
		"mongoose": "^9.x.x"
	},
	"devDependencies": {
		"cpx": "^1.5.0",
		"typedoc": "^0.28.19",
		"typescript": "^6.x.x"
	}
}